#!/bin/bash

## Git credentials — write to global config only.
## Do NOT export GIT_{AUTHOR,COMMITTER}_{NAME,EMAIL}: env vars sit above
## repo-local in git's config hierarchy and would override per-repo
## user.email overrides (e.g. work identities set via post-checkout hooks).
git config --global user.name "Tapani Moilanen"
git config --global user.email "moilanen.tapani@gmail.com"

GIT_HOSTNAME="$(hostname -s 2>/dev/null || printf '%s' unknown)"
case "$GIT_HOSTNAME" in
	bellona)
		GIT_SIGNING_KEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIPmW/hRTl+o67Er8TD0EMhwtlwGElnKNBUxdnpi3bsc6"
		;;
	*)
		GIT_SIGNING_KEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIH+u+pDEuR2CXnAZCJ51U/CzRs51HtJP5bCLiHIQ6nQG"
		;;
esac
git config --global user.signingkey "$GIT_SIGNING_KEY"

## Remote Kafka server
export REMOTE_KAFKA_SERVER=

## Postgres cli shortcuts
alias psqd="psql -h localhost -p 5432 -U postgres"

## Kubectl shortcuts
alias ks="kubectl --context sb"
alias kp="kubectl --context prd"
