#!/bin/bash

## Git credentials
export GIT_AUTHOR_NAME="Tapani Moilanen"
export GIT_COMMITTER_NAME="$GIT_AUTHOR_NAME"
git config --global user.name "$GIT_AUTHOR_NAME"
export GIT_AUTHOR_EMAIL="moilanen.tapani@gmail.com"
export GIT_COMMITTER_EMAIL="$GIT_AUTHOR_EMAIL"
git config --global user.email "$GIT_AUTHOR_EMAIL"

GIT_HOSTNAME="$(hostname -s 2>/dev/null || scutil --get LocalHostName 2>/dev/null || printf '%s' unknown)"
case "$GIT_HOSTNAME" in
	bellona)
		GIT_SIGNING_KEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIPmW/hRTl+o67Er8TD0EMhwtlwGElnKNBUxdnpi3bsc6"
		;;
	*)
		GIT_SIGNING_KEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIH+u+pDEuR2CXnAZCJ51U/CzRs51HtJP5bCLiHIQ6nQG"
		;;
esac
git config --global user.signingkey "$GIT_SIGNING_KEY"

## Remote Kafka server
export REMOTE_KAFKA_SERVER=

## Postgres cli shortcuts
alias psqd="psql -h localhost -p 5432 -U postgres"

## Kubectl shortcuts
alias ks="kubectl --context sb"
alias kp="kubectl --context prd"
